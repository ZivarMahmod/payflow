# =============================================================================
# FlowPay agent secrets — LOCAL ONLY, NEVER COMMITTED
# =============================================================================
# Setup (run once per machine):
#   cp .agent/secrets.env.example .agent/secrets.env
#   # Fill in values from Bitwarden ("Flowpay Supabase" + other entries)
#
# Cowork reads .agent/secrets.env at run start via `source .agent/env.sh`.
# Missing OPTIONAL values just trigger skip-conditions for briefs that
# need them — they do NOT block the whole run.
# Missing REQUIRED values write STOP-SETUP-INCOMPLETE.md and exit.
# =============================================================================

# ---- REQUIRED: Supabase (Flowpay project, eu-north-1, free tier) -----------
SUPABASE_URL=https://nhpmaxtdxkzbauqbkbdk.supabase.co
SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME
SUPABASE_SERVICE_KEY=sb_secret_REPLACE_ME
SUPABASE_DB_PASSWORD=REPLACE_ME

# ---- REQUIRED: GitHub push access ------------------------------------------
GITHUB_PAT=REPLACE_ME

# ---- Mock flags — keep true until prod credentials arrive ------------------
USE_MOCK_ONSLIP=true
USE_MOCK_CASPECO=true
USE_MOCK_SWISH=true
USE_MOCK_STRIPE=true
USE_MOCK_GOOGLE_REVIEWS=true

# ---- OPTIONAL: Stripe Connect (API-005, KI-006 skipped until filled) -------
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- OPTIONAL: Onslip production (POS-001 uses mock if empty) --------------
ONSLIP_API_KEY=
ONSLIP_BASE_URL=

# ---- OPTIONAL: Caspeco OAuth (POS-002 uses mock if empty) ------------------
CASPECO_CLIENT_ID=
CASPECO_CLIENT_SECRET=
CASPECO_TENANT_ID=

# ---- OPTIONAL: Swish Handel (API-003 uses mock if empty) -------------------
SWISH_MERCHANT_ID=
SWISH_CERT_PATH=
SWISH_CERT_PASSWORD=

# ---- OPTIONAL: Google Places (API-006 uses mock if empty) ------------------
GOOGLE_PLACES_API_KEY=
