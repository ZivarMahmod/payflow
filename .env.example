# FlowPay environment variables — copy to .env for local development
# All USE_MOCK_* flags default to true in dev. Set to false when real credentials are wired up.

# ---- Mocks (flip to false when real integrations are ready) ----
USE_MOCK_ONSLIP=true
USE_MOCK_CASPECO=true
USE_MOCK_SWISH=true
USE_MOCK_STRIPE=true
USE_MOCK_GOOGLE=true

# ---- Supabase Cloud (flowpay-prod, eu-north-1) ----
# Fyll från Supabase dashboard → Settings → API.
# SERVICE_KEY är server-side only (aldrig i client bundle).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ---- Stripe (test mode) ----
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ---- Swish (sandbox/mock) ----
SWISH_CERT_PATH=
SWISH_KEY_PATH=
SWISH_MERCHANT_NUMBER=1234679304

# ---- Onslip (sandbox/mock) ----
ONSLIP_API_KEY=

# ---- Caspeco (sandbox/mock) ----
CASPECO_CLIENT_ID=
CASPECO_CLIENT_SECRET=

# ---- General ----
NODE_ENV=development
