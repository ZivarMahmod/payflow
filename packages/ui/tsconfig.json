{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "outDir": "dist",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "tailwind.config.ts"],
  "exclude": ["node_modules", "dist", ".turbo"]
}
