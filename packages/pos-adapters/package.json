{
  "name": "@flowpay/pos-adapters",
  "version": "0.0.1",
  "private": true,
  "description": "FlowPay POS adapters — Onslip / Caspeco / Lightspeed implementations of the POSProvider interface.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./onslip": {
      "types": "./src/onslip/index.ts",
      "default": "./src/onslip/index.ts"
    },
    "./caspeco": {
      "types": "./src/caspeco/index.ts",
      "default": "./src/caspeco/index.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "test": "echo 'no tests yet' && exit 0",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  }
}
