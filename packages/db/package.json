{
  "name": "@flowpay/db",
  "version": "0.0.1",
  "private": true,
  "description": "FlowPay Supabase Cloud dev setup and migrations. Cloud-first — no local Docker.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/database.types.ts",
      "default": "./src/database.types.ts"
    }
  },
  "files": [
    "src",
    "supabase/migrations",
    "supabase/seed.sql"
  ],
  "scripts": {
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "db:diff": "supabase db diff",
    "db:link": "supabase link --project-ref nhpmaxtdxkzbauqbkbdk",
    "db:status": "supabase projects list",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "test": "echo 'no tests' && exit 0",
    "build": "echo 'nothing to build' && exit 0",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "devDependencies": {
    "supabase": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
