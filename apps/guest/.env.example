# Guest PWA environment. Copy to `.env` or `.env.local` for dev.
#
# Only variables prefixed with VITE_ are exposed to the browser bundle —
# DO NOT put Supabase service keys or any secret here.

# FlowPay API base URL (Fastify server from apps/api).
# Dev:        http://localhost:3001
# Staging:    https://api-staging.flowpay.se
# Production: https://api.flowpay.se
VITE_API_URL=http://localhost:3001
