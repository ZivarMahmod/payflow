{
  "name": "@flowpay/api",
  "version": "0.0.1",
  "private": true,
  "description": "FlowPay HTTP API — Fastify + Zod + Supabase. Thin layer over Supabase RPC and POS adapters.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "dependencies": {
    "@flowpay/db": "workspace:*",
    "@flowpay/pos-adapters": "workspace:*",
    "@flowpay/schemas": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@supabase/supabase-js": "^2.46.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
