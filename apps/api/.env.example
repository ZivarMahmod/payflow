# FlowPay API — environment variables.
# Copy to .env for local development. Never commit .env.

# ---- Supabase Cloud (flowpay-prod, eu-north-1) ----
# URL and keys come from Supabase dashboard → Settings → API.
# Service key: server-side only, NEVER in a client bundle.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ---- Mocks (flip to false when real integrations are ready) ----
# When a USE_MOCK_* flag is true, the corresponding adapter returns
# deterministic fixture data instead of calling the real provider.
USE_MOCK_ONSLIP=true
USE_MOCK_CASPECO=true
USE_MOCK_SWISH=true
USE_MOCK_STRIPE=true
USE_MOCK_GOOGLE=true

# ---- API ----
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
# Comma-separated allowlist for CORS. Empty = allow any origin (dev only).
# Production example: CORS_ORIGINS=https://guest.flowpay.se,https://admin.flowpay.se
CORS_ORIGINS=
LOG_LEVEL=info

# ---- POS sync scheduler ----
# Enable on exactly ONE API instance (not every replica). Multiple
# schedulers race but upserts are idempotent — redundant work, not
# incorrect data.
ENABLE_POS_SYNC=false
POS_SYNC_INTERVAL_MS=30000
